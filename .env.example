# 只放非敏感模板。复制为 .env 后 chmod 600；.env 不得提交。

# --- 环境 ---
ENV=production
TZ=Asia/Shanghai
APP_PUBLIC_URL=https://sd.intra.example.com
TEABLE_PUBLIC_ORIGIN=https://teable.sd.intra.example.com
APP_BIND_IP=127.0.0.1
CRON_ENABLED=true

# 镜像必须由 Harbor 管理员填写经过 POC 的不可变 tag/digest，禁止 latest。
POSTGRES_IMAGE=
REDIS_IMAGE=
TEABLE_IMAGE=
SD_WEB_IMAGE=
SD_AGENT_IMAGE=

# --- PostgreSQL ---
POSTGRES_DB=teable
POSTGRES_USER=teable_owner
POSTGRES_PASSWORD=
SD_APP_DB_USER=sd_app_runtime
SD_APP_DB_PASSWORD=
BI_READER_USER=bi_reader
BI_READER_PASSWORD=
SD_APP_DATABASE_URL=
TEABLE_DATABASE_URL=

# --- Redis：Teable 与应用使用独立实例、密码和隔离网络 ---
TEABLE_REDIS_PASSWORD=
APP_REDIS_PASSWORD=
TEABLE_REDIS_URL=
APP_REDIS_URL=

# --- Teable ---
TEABLE_BASE_URL=http://teable:3000
TEABLE_SECRET_KEY=
TEABLE_TOKEN=
TEABLE_TABLE_IDS={}
TEABLE_WEBHOOK_SECRET=
TEABLE_BASE_ID=

# --- 致远 OA ---
OA_BASE_URL=https://oa.intra.example.com/seeyon
OA_REST_USER=
OA_REST_PWD=
OA_REGISTER_CODE=
OA_SENDER_ACCOUNT=sd_agent
OA_CONNECT_TIMEOUT_S=3
OA_READ_TIMEOUT_S=8

# --- 模型服务：独立 GPU-SRV 或集团统一服务 ---
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_S=20
LLM_MAX_CONCURRENCY=4

# --- 会话与安全 ---
JWT_ACTIVE_KID=v1
JWT_SECRET_V1=
JWT_EXPIRE_MINUTES=480
AUTHZ_CACHE_TTL_S=300
CSRF_SECRET=
AUTH_DEV_LOGIN=false
COOKIE_SECURE=true
ALLOWED_REDIRECT_PATHS=/,/home,/mytasks,/map,/ai,/workbench/report,/ledger,/m/report,/m/reply,/m/task,/m/weekly

# --- 文件安全：prod 必须配置可用扫描服务 ---
FILE_SCAN_MODE=required
FILE_SCAN_BASE_URL=
FILE_MAX_MB=20
FILE_ALLOWED_TYPES=application/pdf,image/png,image/jpeg,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

# --- 告警/可观测性 ---
LOG_LEVEL=INFO
ALERT_SMTP_HOST=
ALERT_SMTP_FROM=sd-agent@intra.example.com
ALERT_TO=it-ops@intra.example.com
OTEL_EXPORTER_OTLP_ENDPOINT=
